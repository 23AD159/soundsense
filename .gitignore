# -------------------------------------------------------------
# Models and Data rules
# -------------------------------------------------------------
# Ignore all heavy model files by default (to avoid GitHub 100MB limit)
*.h5
*.tflite

# Explicitly ALLOW the required model files (<100MB) for Render deployment
!backend/models/transfer_model_robust.h5
!backend/models/transfer_model_indian.h5

# Ignore dataset folders
dataset-ESC-50/
backend/data/raw/
backend/data/external/

# Ensure the processed class lists ARE uploaded
!backend/data/processed/classes.npy
!backend/data/processed/indian_classes.npy